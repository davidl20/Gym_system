@page "/register"
@using EvolCep.Shared.Dtos.Auth
@using EvolCep_Frontend.Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Crear Cuenta - EvolCep</PageTitle>

<div class="container py-5 d-flex justify-content-center">
    <div class="card shadow-lg border-0 rounded-4" style="max-width: 600px; width: 100%;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <i class="bi bi-person-plus text-primary" style="font-size: 3rem;"></i>
                <h2 class="fw-bold mt-2">Registro de Usuario</h2>
                <p class="text-muted">Completa tus datos para unirte</p>
            </div>

            <EditForm Model="registerDto" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label small fw-bold">Nombre</label>
                        <InputText @bind-Value="registerDto.Name" class="form-control bg-light" placeholder="Ej: Juan" />
                        <ValidationMessage For="@(() => registerDto.Name)" class="text-danger small" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label small fw-bold">Apellidos</label>
                        <InputText @bind-Value="registerDto.LastName" class="form-control bg-light" placeholder="Ej: Pérez" />
                        <ValidationMessage For="@(() => registerDto.LastName)" class="text-danger small" />
                    </div>

                    <div class="col-md-7 mb-3">
                        <label class="form-label small fw-bold">Email</label>
                        <InputText @bind-Value="registerDto.Email" class="form-control bg-light" placeholder="correo@ejemplo.com" />
                        <ValidationMessage For="@(() => registerDto.Email)" class="text-danger small" />
                    </div>
                    <div class="col-md-5 mb-3">
                        <label class="form-label small fw-bold">Teléfono</label>
                        <InputText @bind-Value="registerDto.PhoneNumber" class="form-control bg-light" placeholder="555-1234" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label small fw-bold">Fecha de Nacimiento</label>
                        <InputDate @bind-Value="registerDto.BirthDate" class="form-control bg-light" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label small fw-bold">Peso (Kg)</label>
                        <InputNumber @bind-Value="registerDto.WeightKg" class="form-control bg-light" step="0.1" />
                    </div>

                    <div class="col-12 mb-4">
                        <label class="form-label small fw-bold">Contraseña</label>
                        <InputText @bind-Value="registerDto.Password" type="password" class="form-control bg-light" placeholder="Mínimo 6 caracteres" />
                        <ValidationMessage For="@(() => registerDto.Password)" class="text-danger small" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger py-2 mb-3 small" role="alert">
                        <i class="bi bi-exclamation-octagon me-2"></i>@errorMessage
                    </div>
                }

                <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span> <span>Registrando...</span>
                    }
                    else
                    {
                        <span>Crear mi cuenta</span>
                    }
                </button>
            </EditForm>

            <div class="text-center mt-4">
                <span class="small text-muted">¿Ya eres miembro?</span>
                <a href="login" class="text-primary fw-bold text-decoration-none small ms-1">Inicia sesión</a>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterDto registerDto = new() { BirthDate = DateTime.Today.AddYears(-20) };
    private string? errorMessage;
    private bool isSubmitting = false;

    private async Task HandleRegister()
    {
        isSubmitting = true;
        errorMessage = null;

        var result = await AuthService.RegisterAsync(registerDto);

        if (result)
        {
            Navigation.NavigateTo("login");
        }
        else
        {
            errorMessage = "No se pudo completar el registro. Verifica que el correo no esté en uso.";
        }

        isSubmitting = false;
    }
}