@page "/"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]

<PageTitle>EvolCep - Bienvenida</PageTitle>

<div class="welcome-container">
    <section class="hero-section text-center py-5 shadow-sm mb-5 bg-white rounded-4">
        <div class="container">
            <div class="py-5">
                <i class="bi bi-layers-half text-primary mb-3" style="font-size: 4.5rem;"></i>
                <h1 class="display-3 fw-bold text-dark">Evol<span class="text-primary">Cep</span></h1>
                <p class="lead text-secondary mx-auto mb-5" style="max-width: 650px;">
                    Gestión avanzada de perfiles y arquitectura de datos.
                    Regístrate para comenzar a optimizar tu flujo de trabajo hoy mismo.
                </p>

                <div class="d-grid gap-3 d-sm-flex justify-content-sm-center mt-4">
                    <a href="login" class="btn btn-primary btn-lg px-5 py-3 shadow-sm fw-bold">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesión
                    </a>
                    <a href="register" class="btn btn-outline-primary btn-lg px-5 py-3 fw-bold">
                        <i class="bi bi-person-plus me-2"></i>Crear una Cuenta
                    </a>
                </div>
            </div>
        </div>
    </section>

    <div id="features" class="container py-4">
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="p-3">
                    <i class="bi bi-shield-check text-primary fs-2"></i>
                    <h5 class="mt-3 fw-bold">Seguridad JWT</h5>
                    <p class="text-muted small">Protección total de tus datos personales.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3">
                    <i class="bi bi-lightning-charge text-primary fs-2"></i>
                    <h5 class="mt-3 fw-bold">Interfaz Rápida</h5>
                    <p class="text-muted small">Experiencia fluida gracias a Blazor WebAssembly.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3">
                    <i class="bi bi-database-check text-primary fs-2"></i>
                    <h5 class="mt-3 fw-bold">SQL Server</h5>
                    <p class="text-muted small">Almacenamiento robusto y confiable.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .welcome-container {
        background-color: #f8f9fa;
        min-height: 85vh;
    }

    .hero-section {
        border-bottom: 1px solid #e9ecef;
    }
</style>