@page "/admin/dashboard"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize (Roles = "Admin")] 

<PageTitle>Panel de Administración - EvolCep</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold"><i class="bi bi-speedometer2 me-2 text-primary"></i>Panel de Control</h2>
            <p class="text-muted">Bienvenido al sistema de gestión de EvolCep.</p>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-primary text-white">
                <div class="d-flex align-items-center">
                    <div class="fs-1 me-3"><i class="bi bi-people"></i></div>
                    <div>
                        <h6 class="mb-0">Usuarios</h6>
                        <h3 class="fw-bold mb-0">124</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-success text-white">
                <div class="d-flex align-items-center">
                    <div class="fs-1 me-3"><i class="bi bi-calendar-check"></i></div>
                    <div>
                        <h6 class="mb-0">Clases Hoy</h6>
                        <h3 class="fw-bold mb-0">8</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="fw-bold">Gestión de Operaciones</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <a href="admin/clases" class="btn btn-light border w-100 p-4 rounded-4 text-start hover-shadow transition">
                                <div class="d-flex align-items-center">
                                    <div class="icon-box bg-primary-subtle text-primary rounded-3 p-3 me-3">
                                        <i class="bi bi-journal-bookmark-fill fs-3"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-1">Gestión de Clases</h6>
                                        <p class="small text-muted mb-0">Crear, editar y asignar horarios.</p>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-md-6">
                            <a href="admin/usuarios" class="btn btn-light border w-100 p-4 rounded-4 text-start hover-shadow transition">
                                <div class="d-flex align-items-center">
                                    <div class="icon-box bg-info-subtle text-info rounded-3 p-3 me-3">
                                        <i class="bi bi-person-gear fs-3"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-1">Usuarios y Roles</h6>
                                        <p class="small text-muted mb-0">Administrar permisos y perfiles.</p>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Actividad Reciente</h5>
                    <ul class="list-unstyled">
                        <li class="mb-3 d-flex small">
                            <i class="bi bi-circle-fill text-primary me-2 mt-1" style="font-size: 0.5rem;"></i>
                            <span>Nueva clase de C# creada por Admin</span>
                        </li>
                        <li class="mb-3 d-flex small">
                            <i class="bi bi-circle-fill text-success me-2 mt-1" style="font-size: 0.5rem;"></i>
                            <span>Usuario "Juan Pérez" se ha registrado</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-shadow:hover {
        background-color: #ffffff !important;
        border-color: var(--bs-primary) !important;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1) !important;
        transform: translateY(-2px);
    }
    .transition {
        transition: all 0.2s ease-in-out;
    }
    .icon-box {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>